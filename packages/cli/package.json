{
  "name": "@alchemist/cli",
  "version": "1.0.0",
  "description": "Alchemist CLI - scaffold and manage projects",
  "main": "lib/index.js",
  "bin": {
    "alchemist": "bin/run.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf lib *.tsbuildinfo",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@alchemist/shared": "*",
    "@alchemist/cmd-generate-next-app": "*",
    "@oclif/core": "^3.15.0",
    "@oclif/plugin-help": "^6.0.6",
    "@oclif/plugin-version": "^1.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "bin": "alchemist",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-version",
      "@alchemist/cmd-generate-next-app"
    ],
    "commands": "./lib/commands"
  }
}

